{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PureSignal",
  "version": "0.1.0",
  "identifier": "dev.v0id.puresignal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "PureSignal",
        "width": 880,
        "height": 720,
        "minWidth": 640,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "dragDropEnabled": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "WhatsApp Status video quality optimizer",
    "longDescription": "Pre-conform videos with a high-effort local encode so WhatsApp Status's re-encode destroys less detail.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/ffmpeg", "binaries/ffprobe"]
  }
}
